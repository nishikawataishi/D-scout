rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================================
    // ヘルパー関数
    // ==========================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.email in ['admin@dscout.app'];
    }

    // 呼び出し元の団体が審査承認済みかチェック
    function isVerifiedOrg() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/organizations/$(request.auth.uid)).data.status == 'verified';
    }

    // ==========================================================
    // users コレクション
    // ==========================================================
    match /users/{userId} {
      // 本人・承認済み団体・管理者のみ閲覧可能
      allow get: if isOwner(userId) || isVerifiedOrg() || isAdmin();
      allow list: if isVerifiedOrg() || isAdmin();
      // updateは本人のみ可能。ただしサーバー管理フィールドは変更不可
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(
          ['isStudentVerified', 'verificationCode', 'codeExpiresAt', 'verifiedAt',
           'verificationAttempts', 'lastCodeSentAt', 'codeHashedValue']
        );
      allow create: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /organizations/{docId} {
      // 個別ドキュメント取得: 承認済みは誰でも、申請中/却下は作成者本人 or 管理者
      allow get: if isAdmin() || (isAuthenticated() && (
        resource.data.status == 'verified' ||
        isOwner(resource.data.representativeId) ||
        isOwner(docId) // 後方互換性：docIdがUIDの場合
      ));
      // コレクションクエリ: 承認済み団体の一覧は全認証ユーザー、全件は管理者のみ
      allow list: if isAdmin() || isAuthenticated();

      // 作成は認証済みユーザーなら誰でも可能だが、初期ステータスは pending 固定
      allow create: if isAuthenticated() &&
                    request.resource.data.status == 'pending' &&
                    request.resource.data.representativeId == request.auth.uid;

      // 更新：管理者はステータス変更可能、オーナーはステータス以外を変更可能
      allow update: if isAdmin() ||
                    ((isOwner(resource.data.representativeId) || isOwner(docId)) &&
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) == false ||
                     request.resource.data.status == resource.data.status));

      // 削除：管理者のみ
      allow delete: if isAdmin();
    }

    // ==========================================================
    // events コレクション
    // ==========================================================
    match /events/{eventId} {
      allow read: if isAuthenticated();
      // 団体UID制限: 審査承認済みの団体のみ作成・更新・削除可能
      allow create: if isVerifiedOrg() && request.resource.data.organizationId == request.auth.uid;
      allow update: if isVerifiedOrg()
                    && resource.data.organizationId == request.auth.uid
                    && request.resource.data.organizationId == request.auth.uid;
      allow delete: if isVerifiedOrg() && resource.data.organizationId == request.auth.uid;

      // ── イベント申し込み（applications サブコレクション） ──
      match /applications/{applicationId} {
        // 読み取り: 申し込んだ学生本人 または イベント主催団体
        allow get: if isAuthenticated() && (
          request.auth.uid == applicationId ||
          get(/databases/$(database)/documents/events/$(eventId)).data.organizationId == request.auth.uid
        );
        // 一覧取得: イベント主催団体のみ（学生は自分の申し込みは get で取得）
        allow list: if isAuthenticated() &&
          get(/databases/$(database)/documents/events/$(eventId)).data.organizationId == request.auth.uid;

        // 作成: 認証済み学生のみ。docIDは自分のUID固定で1人1申し込みを保証。初期ステータスは applied 固定
        allow create: if isAuthenticated()
                      && applicationId == request.auth.uid
                      && request.resource.data.studentId == request.auth.uid
                      && request.resource.data.status == 'applied';

        // 更新: 主催団体がステータスと respondedAt のみ変更可能
        allow update: if isAuthenticated()
                      && get(/databases/$(database)/documents/events/$(eventId)).data.organizationId == request.auth.uid
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt']);

        // 削除（キャンセル）: 申し込んだ学生本人のみ
        allow delete: if isAuthenticated() && request.auth.uid == applicationId;
      }
    }

    // ==========================================================
    // scouts コレクション
    // ==========================================================
    match /scouts/{docId} {
      // 読み取りはスカウト対象の学生、または送信元の団体のみ
      allow get: if isAuthenticated() &&
        (request.auth.uid == resource.data.targetUserId ||
         request.auth.uid == resource.data.organizationId);
      // listクエリはwhere条件でtargetUserIdまたはorganizationIdが自分のUIDである必要がある
      allow list: if isAuthenticated();

      // 更新（既読フラグなど）は対象学生のみ、かつisReadとreadAtのみ更新可能
      allow update: if isAuthenticated()
                    && request.auth.uid == resource.data.targetUserId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);

      // 作成は審査承認済みの団体のみ。メッセージは1〜500文字
      allow create: if isVerifiedOrg()
                    && request.resource.data.organizationId == request.auth.uid
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 500;
    }

    // ==========================================================
    // contacts コレクション（お問い合わせ）
    // ==========================================================
    match /contacts/{docId} {
      // 作成: 認証済みユーザーが自分のUIDを含む問い合わせのみ送信可能
      allow create: if isAuthenticated() &&
                    request.resource.data.userId == request.auth.uid;
      // 読み取り・更新・削除: 管理者のみ
      allow read, update, delete: if isAdmin();
    }

    // ==========================================================
    // tags コレクション（タグマスタ）
    // ==========================================================
    match /tags/{docId} {
      // 認証済みユーザーなら誰でも読み取り可能
      allow read: if isAuthenticated();
      // 認証済みユーザーなら誰でもタグを追加可能
      allow create: if isAuthenticated();
      // 削除は管理者のみ
      allow delete: if isAdmin();
      // 更新は管理者のみ
      allow update: if isAdmin();
    }
  }
}
