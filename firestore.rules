rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================================
    // ヘルパー関数
    // ==========================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ==========================================================
    // users コレクション
    // ==========================================================
    match /users/{userId} {
      // 本人は読み込み可能。加えて団体（OrgDashboard用）は他ユーザーの公開プロフを検索・閲覧可能とする
      allow read: if isAuthenticated();
      // list を特別に許可 (OrgDashboardが getStudents() で name isNotEqualTo null で引っ張ってくるため)
      allow list: if isAuthenticated();
      // updateは本人のみ可能。isStudentVerified等は直接変更させないようなバリデーションなどが必要だが、MVPなので一旦本人許可
      allow update: if isOwner(userId);
      allow create: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ==========================================================
    // organizations コレクション
    // ==========================================================
    match /organizations/{docId} {
      allow read: if isAuthenticated();
      // 団体UID制限: 自身のドキュメントのみ作成・変更可能
      allow write: if isOwner(docId);
    }

    // ==========================================================
    // events コレクション
    // ==========================================================
    match /events/{docId} {
      allow read: if isAuthenticated();
      // 団体UID制限: 自身のorganizationIdに紐づくイベントのみ作成・更新・削除可能
      allow create: if isAuthenticated() && request.resource.data.organizationId == request.auth.uid;
      allow update: if isAuthenticated() 
                    && resource.data.organizationId == request.auth.uid
                    && request.resource.data.organizationId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.organizationId == request.auth.uid;
    }

    // ==========================================================
    // scouts コレクション
    // ==========================================================
    match /scouts/{docId} {
      // 読み取りはスカウトされた本人、及び送信元の団体ユーザー（MVPでは全員に仮許可）
      allow read: if isAuthenticated();
      
      // 更新（既読フラグなど）は本人のみ、かつisReadとreadAtのみ更新可能
      allow update: if isAuthenticated() 
                    && request.auth.uid == resource.data.targetUserId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
      
      // 作成は送信元の団体アカウントのみ許可
      allow create: if isAuthenticated() 
                    && request.resource.data.organizationId == request.auth.uid;
    }
  }
}
